FROM debian:bookworm-slim AS base
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl jq python3 ca-certificates xz-utils && rm -rf /var/lib/apt/lists/*
RUN curl -L https://ziglang.org/download/0.13.0/zig-linux-$(dpkg --print-architecture)-0.13.0.tar.xz | tar xJ -C /opt \
    && ln -s /opt/zig-linux-*/zig /usr/local/bin/zig
RUN zig version
WORKDIR /tutorials
CMD ["bash"]
