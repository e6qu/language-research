FROM debian:bookworm-slim AS base
RUN apt-get update && apt-get install -y --no-install-recommends make \
    curl jq python3 ca-certificates xz-utils && rm -rf /var/lib/apt/lists/*
RUN ARCH=$(dpkg --print-architecture | sed 's/amd64/x86_64/;s/arm64/aarch64/') \
    && curl -L "https://ziglang.org/download/0.14.0/zig-linux-${ARCH}-0.14.0.tar.xz" | tar xJ -C /opt \
    && ln -s /opt/zig-linux-*/zig /usr/local/bin/zig
RUN zig version
WORKDIR /tutorials
CMD ["bash"]
